{
  "name": "@vivantel/virage-chunker-ce-ts",
  "version": "0.1.1",
  "description": "TypeScript / JavaScript chunker for Virage — pure TypeScript, no native binary",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --build",
    "type-check": "tsc --build --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@vivantel/virage-chunker-ce-ast": ">=0.1"
  },
  "dependencies": {
    "minimatch": "^10.0.0",
    "typescript": "^6.0.3"
  },
  "rag-plugin": {
    "type": "chunker",
    "label": "TypeScript / JavaScript",
    "key": "ts",
    "defaultConfig": {
      "maxTokens": 512
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT OR Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/vivantel/virage-chunkers-ce.git",
    "directory": "packages/virage-chunker-ce-ts"
  }
}
