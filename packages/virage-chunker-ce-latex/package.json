{
  "name": "@vivantel/virage-chunker-ce-latex",
  "version": "0.1.0",
  "description": "LaTeX chunker for Virage — Rust napi-rs native addon (custom lexer/parser)",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types":  "./dist/index.d.ts"
    }
  },
  "files": ["dist", "npm", "*.node"],
  "scripts": {
    "build":          "tsc --build",
    "build:native":   "napi build --release --platform",
    "type-check":     "tsc --build --noEmit",
    "test":           "vitest run",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@vivantel/virage-core":           ">=0.2",
    "@vivantel/virage-chunker-ce-ast": ">=0.1"
  },
  "dependencies": {
    "minimatch": "^10.0.0"
  },
  "optionalDependencies": {
    "@vivantel/virage-chunker-ce-latex-linux-x64-gnu":   "0.1.0",
    "@vivantel/virage-chunker-ce-latex-linux-arm64-gnu": "0.1.0",
    "@vivantel/virage-chunker-ce-latex-darwin-x64":      "0.1.0",
    "@vivantel/virage-chunker-ce-latex-darwin-arm64":    "0.1.0",
    "@vivantel/virage-chunker-ce-latex-win32-x64-msvc":  "0.1.0"
  },
  "rag-plugin": {
    "type": "chunker",
    "label": "LaTeX",
    "key": "latex",
    "defaultConfig": {
      "maxTokens": 512,
      "overlapSentences": 1
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT OR Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/vivantel/virage-chunkers-ce.git",
    "directory": "packages/virage-chunker-ce-latex"
  }
}
