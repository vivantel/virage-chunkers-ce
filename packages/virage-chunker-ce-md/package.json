{
  "name": "@vivantel/virage-chunker-ce-md",
  "version": "0.1.5",
  "description": "Markdown / MDX chunker for Virage — Rust napi-rs native addon (comrak)",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "npm",
    "*.node"
  ],
  "scripts": {
    "build": "tsc --build",
    "build:native": "napi build --release --platform",
    "type-check": "tsc --build --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@vivantel/virage-core": ">=0.2",
    "@vivantel/virage-chunker-ce-ast": ">=0.1"
  },
  "dependencies": {
    "minimatch": "^10.0.0"
  },
  "optionalDependencies": {
    "@vivantel/virage-chunker-ce-md-linux-x64-gnu": "0.1.7",
    "@vivantel/virage-chunker-ce-md-linux-arm64-gnu": "0.1.7",
    "@vivantel/virage-chunker-ce-md-darwin-x64": "0.1.7",
    "@vivantel/virage-chunker-ce-md-darwin-arm64": "0.1.7",
    "@vivantel/virage-chunker-ce-md-win32-x64-msvc": "0.1.7"
  },
  "rag-plugin": {
    "type": "chunker",
    "label": "Markdown / MDX",
    "key": "md",
    "defaultConfig": {
      "maxTokens": 512,
      "overlapSentences": 1
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT OR Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/vivantel/virage-chunkers-ce.git",
    "directory": "packages/virage-chunker-ce-md"
  }
}
