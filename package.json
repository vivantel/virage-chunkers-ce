{
  "name": "virage-chunkers-ce-monorepo",
  "private": true,
  "type": "module",
  "workspaces": ["packages/*"],
  "scripts": {
    "build":          "npm run build --workspaces --if-present",
    "test":           "vitest run --reporter=verbose",
    "bench":          "vitest bench bench/",
    "type-check":     "npm run type-check --workspaces --if-present",
    "lint":           "eslint \"packages/*/src/**/*.ts\" \"packages/*/src-ts/**/*.ts\"",
    "lint:fix":       "eslint \"packages/*/src/**/*.ts\" \"packages/*/src-ts/**/*.ts\" --fix",
    "format":         "prettier --write \"packages/*/src/**/*.ts\" \"packages/*/src-ts/**/*.ts\"",
    "format:check":   "prettier --check \"packages/*/src/**/*.ts\" \"packages/*/src-ts/**/*.ts\"",
    "fix":            "npm run lint:fix && npm run format",
    "clean":          "rm -rf packages/*/dist packages/*/node_modules node_modules target",
    "prepare":        "git config core.hooksPath .githooks 2>/dev/null || true",
    "postinstall":    "node scripts/patch-lockfile-stubs.cjs"
  },
  "devDependencies": {
    "@eslint/js":        "^10.0.0",
    "@napi-rs/cli":      "^3.7.2",
    "@types/node":        "^26.0.1",
    "eslint":             "^10.6.0",
    "prettier":           "^3.9.3",
    "typescript":         "^6.0.3",
    "typescript-eslint":  "^8.62.1",
    "vitest":             "^4.1.9"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
