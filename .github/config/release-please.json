{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "node",
  "separate-pull-requests": false,
  "tag-separator": "@",
  "include-component-in-tag": true,
  "include-v-in-tag": true,
  "pull-request-title-pattern": "chore: release ${version}",
  "changelog-sections": [
    { "type": "feat",     "section": "Features" },
    { "type": "fix",      "section": "Bug Fixes" },
    { "type": "perf",     "section": "Performance Improvements" },
    { "type": "refactor", "section": "Code Refactoring" },
    { "type": "docs",     "section": "Documentation" },
    { "type": "style",    "section": "Miscellaneous", "hidden": true },
    { "type": "test",     "section": "Miscellaneous", "hidden": true },
    { "type": "chore",    "section": "Miscellaneous", "hidden": true }
  ],
  "packages": {
    "packages/virage-chunker-ce-ast": {
      "bump-minor-pre-major": true,
      "bump-patch-for-minor-pre-major": true
    },
    "packages/virage-chunker-ce-pdf": {
      "bump-minor-pre-major": true,
      "bump-patch-for-minor-pre-major": true,
      "extra-files": [
        { "type": "json", "path": "npm/linux-x64-gnu/package.json",  "jsonpath": "$.version" },
        { "type": "json", "path": "npm/linux-arm64-gnu/package.json","jsonpath": "$.version" },
        { "type": "json", "path": "npm/darwin-x64/package.json",     "jsonpath": "$.version" },
        { "type": "json", "path": "npm/darwin-arm64/package.json",   "jsonpath": "$.version" },
        { "type": "json", "path": "npm/win32-x64-msvc/package.json", "jsonpath": "$.version" },
        { "type": "json", "path": "package.json", "jsonpath": "$.optionalDependencies['@vivantel/virage-chunker-ce-pdf-linux-x64-gnu']" },
        { "type": "json", "path": "package.json", "jsonpath": "$.optionalDependencies['@vivantel/virage-chunker-ce-pdf-linux-arm64-gnu']" },
        { "type": "json", "path": "package.json", "jsonpath": "$.optionalDependencies['@vivantel/virage-chunker-ce-pdf-darwin-x64']" },
        { "type": "json", "path": "package.json", "jsonpath": "$.optionalDependencies['@vivantel/virage-chunker-ce-pdf-darwin-arm64']" },
        { "type": "json", "path": "package.json", "jsonpath": "$.optionalDependencies['@vivantel/virage-chunker-ce-pdf-win32-x64-msvc']" }
      ]
    },
    "packages/virage-chunker-ce-md": {
      "bump-minor-pre-major": true,
      "bump-patch-for-minor-pre-major": true,
      "extra-files": [
        { "type": "json", "path": "npm/linux-x64-gnu/package.json",  "jsonpath": "$.version" },
        { "type": "json", "path": "npm/linux-arm64-gnu/package.json","jsonpath": "$.version" },
        { "type": "json", "path": "npm/darwin-x64/package.json",     "jsonpath": "$.version" },
        { "type": "json", "path": "npm/darwin-arm64/package.json",   "jsonpath": "$.version" },
        { "type": "json", "path": "npm/win32-x64-msvc/package.json", "jsonpath": "$.version" },
        { "type": "json", "path": "package.json", "jsonpath": "$.optionalDependencies['@vivantel/virage-chunker-ce-md-linux-x64-gnu']" },
        { "type": "json", "path": "package.json", "jsonpath": "$.optionalDependencies['@vivantel/virage-chunker-ce-md-linux-arm64-gnu']" },
        { "type": "json", "path": "package.json", "jsonpath": "$.optionalDependencies['@vivantel/virage-chunker-ce-md-darwin-x64']" },
        { "type": "json", "path": "package.json", "jsonpath": "$.optionalDependencies['@vivantel/virage-chunker-ce-md-darwin-arm64']" },
        { "type": "json", "path": "package.json", "jsonpath": "$.optionalDependencies['@vivantel/virage-chunker-ce-md-win32-x64-msvc']" }
      ]
    },
    "packages/virage-chunker-ce-docx": {
      "bump-minor-pre-major": true,
      "bump-patch-for-minor-pre-major": true,
      "extra-files": [
        { "type": "json", "path": "npm/linux-x64-gnu/package.json",  "jsonpath": "$.version" },
        { "type": "json", "path": "npm/linux-arm64-gnu/package.json","jsonpath": "$.version" },
        { "type": "json", "path": "npm/darwin-x64/package.json",     "jsonpath": "$.version" },
        { "type": "json", "path": "npm/darwin-arm64/package.json",   "jsonpath": "$.version" },
        { "type": "json", "path": "npm/win32-x64-msvc/package.json", "jsonpath": "$.version" },
        { "type": "json", "path": "package.json", "jsonpath": "$.optionalDependencies['@vivantel/virage-chunker-ce-docx-linux-x64-gnu']" },
        { "type": "json", "path": "package.json", "jsonpath": "$.optionalDependencies['@vivantel/virage-chunker-ce-docx-linux-arm64-gnu']" },
        { "type": "json", "path": "package.json", "jsonpath": "$.optionalDependencies['@vivantel/virage-chunker-ce-docx-darwin-x64']" },
        { "type": "json", "path": "package.json", "jsonpath": "$.optionalDependencies['@vivantel/virage-chunker-ce-docx-darwin-arm64']" },
        { "type": "json", "path": "package.json", "jsonpath": "$.optionalDependencies['@vivantel/virage-chunker-ce-docx-win32-x64-msvc']" }
      ]
    },
    "packages/virage-chunker-ce-latex": {
      "bump-minor-pre-major": true,
      "bump-patch-for-minor-pre-major": true,
      "extra-files": [
        { "type": "json", "path": "npm/linux-x64-gnu/package.json",  "jsonpath": "$.version" },
        { "type": "json", "path": "npm/linux-arm64-gnu/package.json","jsonpath": "$.version" },
        { "type": "json", "path": "npm/darwin-x64/package.json",     "jsonpath": "$.version" },
        { "type": "json", "path": "npm/darwin-arm64/package.json",   "jsonpath": "$.version" },
        { "type": "json", "path": "npm/win32-x64-msvc/package.json", "jsonpath": "$.version" },
        { "type": "json", "path": "package.json", "jsonpath": "$.optionalDependencies['@vivantel/virage-chunker-ce-latex-linux-x64-gnu']" },
        { "type": "json", "path": "package.json", "jsonpath": "$.optionalDependencies['@vivantel/virage-chunker-ce-latex-linux-arm64-gnu']" },
        { "type": "json", "path": "package.json", "jsonpath": "$.optionalDependencies['@vivantel/virage-chunker-ce-latex-darwin-x64']" },
        { "type": "json", "path": "package.json", "jsonpath": "$.optionalDependencies['@vivantel/virage-chunker-ce-latex-darwin-arm64']" },
        { "type": "json", "path": "package.json", "jsonpath": "$.optionalDependencies['@vivantel/virage-chunker-ce-latex-win32-x64-msvc']" }
      ]
    },
    "packages/virage-chunker-ce-ts": {
      "bump-minor-pre-major": true,
      "bump-patch-for-minor-pre-major": true
    }
  },
  "plugins": [
    { "type": "node-workspace" },
    { "type": "sentence-case" }
  ]
}
